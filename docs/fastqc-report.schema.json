{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai4s-yb.github.io/fastqc-rs/schemas/fastqc-report-v1.schema.json",
  "title": "fastqc-rs Structured Report",
  "description": "Proposed structured JSON output for a single fastqc-rs report. The shape is designed to map directly to the internal module state in fastqc-rs while staying convenient for RustBrain frontend consumption.",
  "type": "object",
  "required": [
    "schema_version",
    "generated_by",
    "generated_at",
    "input",
    "summary",
    "modules"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Schema version for the structured report payload."
    },
    "generated_by": {
      "type": "object",
      "required": [
        "tool",
        "version"
      ],
      "properties": {
        "tool": {
          "type": "string",
          "const": "fastqc-rs"
        },
        "version": {
          "type": "string",
          "description": "fastqc-rs version that produced the payload."
        }
      },
      "additionalProperties": false
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 timestamp for report generation."
    },
    "input": {
      "type": "object",
      "required": [
        "file_name",
        "source_path",
        "detected_format"
      ],
      "properties": {
        "file_name": {
          "type": "string"
        },
        "source_path": {
          "type": "string",
          "description": "Original input path or stdin marker."
        },
        "detected_format": {
          "type": "string",
          "enum": [
            "fastq",
            "bam",
            "sam",
            "bam_mapped",
            "sam_mapped"
          ]
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": [
        "overall_status",
        "module_counts",
        "basic_statistics"
      ],
      "properties": {
        "overall_status": {
          "$ref": "#/$defs/overallStatus"
        },
        "module_counts": {
          "type": "object",
          "required": [
            "pass",
            "warn",
            "fail",
            "not_applicable"
          ],
          "properties": {
            "pass": {
              "type": "integer",
              "minimum": 0
            },
            "warn": {
              "type": "integer",
              "minimum": 0
            },
            "fail": {
              "type": "integer",
              "minimum": 0
            },
            "not_applicable": {
              "type": "integer",
              "minimum": 0
            }
          },
          "additionalProperties": false
        },
        "basic_statistics": {
          "type": "object",
          "required": [
            "total_sequences",
            "filtered_sequences",
            "total_bases",
            "min_sequence_length",
            "max_sequence_length",
            "gc_percent"
          ],
          "properties": {
            "total_sequences": {
              "type": "integer",
              "minimum": 0
            },
            "filtered_sequences": {
              "type": "integer",
              "minimum": 0
            },
            "total_bases": {
              "type": "integer",
              "minimum": 0
            },
            "min_sequence_length": {
              "type": "integer",
              "minimum": 0
            },
            "max_sequence_length": {
              "type": "integer",
              "minimum": 0
            },
            "gc_percent": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "modules": {
      "type": "array",
      "description": "All 12 FastQC modules in canonical order. Modules that would normally be omitted from text/html output should still appear here with status=not_applicable and in_report=false.",
      "prefixItems": [
        {
          "$ref": "#/$defs/basicStatisticsModule"
        },
        {
          "$ref": "#/$defs/perBaseSequenceQualityModule"
        },
        {
          "$ref": "#/$defs/perTileSequenceQualityModule"
        },
        {
          "$ref": "#/$defs/perSequenceQualityScoresModule"
        },
        {
          "$ref": "#/$defs/perBaseSequenceContentModule"
        },
        {
          "$ref": "#/$defs/perSequenceGcContentModule"
        },
        {
          "$ref": "#/$defs/perBaseNContentModule"
        },
        {
          "$ref": "#/$defs/sequenceLengthDistributionModule"
        },
        {
          "$ref": "#/$defs/sequenceDuplicationLevelsModule"
        },
        {
          "$ref": "#/$defs/overrepresentedSequencesModule"
        },
        {
          "$ref": "#/$defs/adapterContentModule"
        },
        {
          "$ref": "#/$defs/kmerContentModule"
        }
      ],
      "items": false,
      "minItems": 12,
      "maxItems": 12
    }
  },
  "additionalProperties": false,
  "$defs": {
    "moduleStatus": {
      "type": "string",
      "enum": [
        "pass",
        "warn",
        "fail",
        "not_applicable"
      ]
    },
    "overallStatus": {
      "type": "string",
      "enum": [
        "pass",
        "warn",
        "fail"
      ]
    },
    "thresholds": {
      "type": "object",
      "properties": {
        "warn": {
          "type": "number"
        },
        "error": {
          "type": "number"
        }
      },
      "required": [
        "warn",
        "error"
      ],
      "additionalProperties": false
    },
    "moduleBase": {
      "type": "object",
      "required": [
        "id",
        "name",
        "status",
        "in_report",
        "data"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/moduleStatus"
        },
        "in_report": {
          "type": "boolean"
        },
        "omitted_reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "thresholds": {
          "$ref": "#/$defs/thresholds"
        },
        "data": {
          "type": "object"
        }
      }
    },
    "groupedPositionPoint": {
      "type": "object",
      "required": [
        "label"
      ],
      "properties": {
        "label": {
          "type": "string",
          "description": "FastQC-style grouped base label, e.g. 1, 2-5, 10-14."
        }
      }
    },
    "basicStatisticsModule": {
      "allOf": [
        {
          "$ref": "#/$defs/moduleBase"
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "const": "basic_statistics"
            },
            "name": {
              "const": "Basic Statistics"
            },
            "thresholds": false,
            "data": {
              "type": "object",
              "required": [
                "file_name",
                "file_type",
                "encoding",
                "total_sequences",
                "filtered_sequences",
                "total_bases",
                "total_bases_human",
                "sequence_length",
                "gc_percent"
              ],
              "properties": {
                "file_name": {
                  "type": "string"
                },
                "file_type": {
                  "type": "string"
                },
                "encoding": {
                  "type": "string"
                },
                "total_sequences": {
                  "type": "integer",
                  "minimum": 0
                },
                "filtered_sequences": {
                  "type": "integer",
                  "minimum": 0
                },
                "total_bases": {
                  "type": "integer",
                  "minimum": 0
                },
                "total_bases_human": {
                  "type": "string",
                  "description": "Human-readable display string, e.g. 1.5 Mbp."
                },
                "sequence_length": {
                  "type": "object",
                  "required": [
                    "min",
                    "max",
                    "display"
                  ],
                  "properties": {
                    "min": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "max": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "display": {
                      "type": "string"
                    }
                  },
                  "additionalProperties": false
                },
                "gc_percent": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 100
                }
              },
              "additionalProperties": false
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "perBaseSequenceQualityModule": {
      "allOf": [
        {
          "$ref": "#/$defs/moduleBase"
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "const": "per_base_sequence_quality"
            },
            "name": {
              "const": "Per base sequence quality"
            },
            "thresholds": {
              "type": "object",
              "required": [
                "warn_lower",
                "warn_median",
                "error_lower",
                "error_median"
              ],
              "properties": {
                "warn_lower": {
                  "type": "number"
                },
                "warn_median": {
                  "type": "number"
                },
                "error_lower": {
                  "type": "number"
                },
                "error_median": {
                  "type": "number"
                }
              },
              "additionalProperties": false
            },
            "data": {
              "type": "object",
              "required": [
                "encoding",
                "position_groups"
              ],
              "properties": {
                "encoding": {
                  "type": "string"
                },
                "position_groups": {
                  "type": "array",
                  "items": {
                    "allOf": [
                      {
                        "$ref": "#/$defs/groupedPositionPoint"
                      },
                      {
                        "type": "object",
                        "required": [
                          "mean",
                          "median",
                          "lower_quartile",
                          "upper_quartile",
                          "percentile_10",
                          "percentile_90"
                        ],
                        "properties": {
                          "mean": {
                            "type": "number"
                          },
                          "median": {
                            "type": "number"
                          },
                          "lower_quartile": {
                            "type": "number"
                          },
                          "upper_quartile": {
                            "type": "number"
                          },
                          "percentile_10": {
                            "type": "number"
                          },
                          "percentile_90": {
                            "type": "number"
                          }
                        }
                      }
                    ],
                    "unevaluatedProperties": false
                  }
                }
              },
              "additionalProperties": false
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "perTileSequenceQualityModule": {
      "allOf": [
        {
          "$ref": "#/$defs/moduleBase"
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "const": "per_tile_sequence_quality"
            },
            "name": {
              "const": "Per tile sequence quality"
            },
            "thresholds": {
              "$ref": "#/$defs/thresholds"
            },
            "data": {
              "type": "object",
              "required": [
                "max_deviation",
                "position_groups",
                "tiles"
              ],
              "properties": {
                "max_deviation": {
                  "type": "number"
                },
                "position_groups": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "tiles": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": [
                      "tile",
                      "mean_deviation"
                    ],
                    "properties": {
                      "tile": {
                        "type": "integer"
                      },
                      "mean_deviation": {
                        "type": "array",
                        "items": {
                          "type": "number"
                        }
                      }
                    },
                    "additionalProperties": false
                  }
                }
              },
              "additionalProperties": false
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "perSequenceQualityScoresModule": {
      "allOf": [
        {
          "$ref": "#/$defs/moduleBase"
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "const": "per_sequence_quality_scores"
            },
            "name": {
              "const": "Per sequence quality scores"
            },
            "thresholds": {
              "$ref": "#/$defs/thresholds"
            },
            "data": {
              "type": "object",
              "required": [
                "encoding",
                "most_frequent_score",
                "distribution"
              ],
              "properties": {
                "encoding": {
                  "type": "string"
                },
                "most_frequent_score": {
                  "type": "integer"
                },
                "distribution": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": [
                      "quality",
                      "count"
                    ],
                    "properties": {
                      "quality": {
                        "type": "integer"
                      },
                      "count": {
                        "type": "number",
                        "minimum": 0
                      }
                    },
                    "additionalProperties": false
                  }
                }
              },
              "additionalProperties": false
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "perBaseSequenceContentModule": {
      "allOf": [
        {
          "$ref": "#/$defs/moduleBase"
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "const": "per_base_sequence_content"
            },
            "name": {
              "const": "Per base sequence content"
            },
            "thresholds": {
              "$ref": "#/$defs/thresholds"
            },
            "data": {
              "type": "object",
              "required": [
                "position_groups"
              ],
              "properties": {
                "position_groups": {
                  "type": "array",
                  "items": {
                    "allOf": [
                      {
                        "$ref": "#/$defs/groupedPositionPoint"
                      },
                      {
                        "type": "object",
                        "required": [
                          "g_pct",
                          "a_pct",
                          "t_pct",
                          "c_pct"
                        ],
                        "properties": {
                          "g_pct": {
                            "type": "number"
                          },
                          "a_pct": {
                            "type": "number"
                          },
                          "t_pct": {
                            "type": "number"
                          },
                          "c_pct": {
                            "type": "number"
                          }
                        }
                      }
                    ],
                    "unevaluatedProperties": false
                  }
                }
              },
              "additionalProperties": false
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "perSequenceGcContentModule": {
      "allOf": [
        {
          "$ref": "#/$defs/moduleBase"
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "const": "per_sequence_gc_content"
            },
            "name": {
              "const": "Per sequence GC content"
            },
            "thresholds": {
              "$ref": "#/$defs/thresholds"
            },
            "data": {
              "type": "object",
              "required": [
                "deviation_percent",
                "distribution"
              ],
              "properties": {
                "deviation_percent": {
                  "type": "number"
                },
                "distribution": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": [
                      "gc_percent",
                      "observed_count",
                      "theoretical_count"
                    ],
                    "properties": {
                      "gc_percent": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 100
                      },
                      "observed_count": {
                        "type": "number",
                        "minimum": 0
                      },
                      "theoretical_count": {
                        "type": "number",
                        "minimum": 0
                      }
                    },
                    "additionalProperties": false
                  }
                }
              },
              "additionalProperties": false
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "perBaseNContentModule": {
      "allOf": [
        {
          "$ref": "#/$defs/moduleBase"
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "const": "per_base_n_content"
            },
            "name": {
              "const": "Per base N content"
            },
            "thresholds": {
              "$ref": "#/$defs/thresholds"
            },
            "data": {
              "type": "object",
              "required": [
                "position_groups"
              ],
              "properties": {
                "position_groups": {
                  "type": "array",
                  "items": {
                    "allOf": [
                      {
                        "$ref": "#/$defs/groupedPositionPoint"
                      },
                      {
                        "type": "object",
                        "required": [
                          "n_pct"
                        ],
                        "properties": {
                          "n_pct": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 100
                          }
                        }
                      }
                    ],
                    "unevaluatedProperties": false
                  }
                }
              },
              "additionalProperties": false
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "sequenceLengthDistributionModule": {
      "allOf": [
        {
          "$ref": "#/$defs/moduleBase"
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "const": "sequence_length_distribution"
            },
            "name": {
              "const": "Sequence Length Distribution"
            },
            "thresholds": false,
            "data": {
              "type": "object",
              "required": [
                "min_observed_length",
                "max_observed_length",
                "interval",
                "distribution"
              ],
              "properties": {
                "min_observed_length": {
                  "type": "integer",
                  "minimum": 0
                },
                "max_observed_length": {
                  "type": "integer",
                  "minimum": 0
                },
                "interval": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Display grouping interval used for the emitted distribution."
                },
                "distribution": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": [
                      "label",
                      "count"
                    ],
                    "properties": {
                      "label": {
                        "type": "string"
                      },
                      "count": {
                        "type": "number",
                        "minimum": 0
                      }
                    },
                    "additionalProperties": false
                  }
                }
              },
              "additionalProperties": false
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "sequenceDuplicationLevelsModule": {
      "allOf": [
        {
          "$ref": "#/$defs/moduleBase"
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "const": "sequence_duplication_levels"
            },
            "name": {
              "const": "Sequence Duplication Levels"
            },
            "thresholds": {
              "$ref": "#/$defs/thresholds"
            },
            "data": {
              "type": "object",
              "required": [
                "deduplicated_percentage",
                "distribution"
              ],
              "properties": {
                "deduplicated_percentage": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 100
                },
                "distribution": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": [
                      "label",
                      "percentage_of_total"
                    ],
                    "properties": {
                      "label": {
                        "type": "string"
                      },
                      "percentage_of_total": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 100
                      }
                    },
                    "additionalProperties": false
                  }
                }
              },
              "additionalProperties": false
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "overrepresentedSequencesModule": {
      "allOf": [
        {
          "$ref": "#/$defs/moduleBase"
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "const": "overrepresented_sequences"
            },
            "name": {
              "const": "Overrepresented sequences"
            },
            "thresholds": {
              "$ref": "#/$defs/thresholds"
            },
            "data": {
              "type": "object",
              "required": [
                "total_sequences_considered",
                "unique_sequence_count",
                "sampling_frozen",
                "count_at_unique_limit",
                "records"
              ],
              "properties": {
                "total_sequences_considered": {
                  "type": "integer",
                  "minimum": 0
                },
                "unique_sequence_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "sampling_frozen": {
                  "type": "boolean",
                  "description": "True when the unique-sequence observation cutoff was hit and new unique sequences were no longer tracked."
                },
                "count_at_unique_limit": {
                  "type": "integer",
                  "minimum": 0
                },
                "records": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": [
                      "sequence",
                      "count",
                      "percentage",
                      "possible_source"
                    ],
                    "properties": {
                      "sequence": {
                        "type": "string"
                      },
                      "count": {
                        "type": "integer",
                        "minimum": 0
                      },
                      "percentage": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 100
                      },
                      "possible_source": {
                        "type": "string"
                      }
                    },
                    "additionalProperties": false
                  }
                }
              },
              "additionalProperties": false
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "adapterContentModule": {
      "allOf": [
        {
          "$ref": "#/$defs/moduleBase"
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "const": "adapter_content"
            },
            "name": {
              "const": "Adapter Content"
            },
            "thresholds": {
              "$ref": "#/$defs/thresholds"
            },
            "data": {
              "type": "object",
              "required": [
                "total_sequences_considered",
                "max_read_length",
                "max_adapter_length",
                "read_length_too_short",
                "position_groups",
                "series"
              ],
              "properties": {
                "total_sequences_considered": {
                  "type": "integer",
                  "minimum": 0
                },
                "max_read_length": {
                  "type": "integer",
                  "minimum": 0
                },
                "max_adapter_length": {
                  "type": "integer",
                  "minimum": 0
                },
                "read_length_too_short": {
                  "type": "boolean"
                },
                "position_groups": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "series": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": [
                      "adapter_name",
                      "adapter_sequence",
                      "values"
                    ],
                    "properties": {
                      "adapter_name": {
                        "type": "string"
                      },
                      "adapter_sequence": {
                        "type": "string"
                      },
                      "values": {
                        "type": "array",
                        "items": {
                          "type": "number",
                          "minimum": 0,
                          "maximum": 100
                        }
                      }
                    },
                    "additionalProperties": false
                  }
                }
              },
              "additionalProperties": false
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "kmerContentModule": {
      "allOf": [
        {
          "$ref": "#/$defs/moduleBase"
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "const": "kmer_content"
            },
            "name": {
              "const": "Kmer Content"
            },
            "thresholds": {
              "$ref": "#/$defs/thresholds"
            },
            "data": {
              "type": "object",
              "required": [
                "kmer_size",
                "sampled_every_n_reads",
                "estimated_count_multiplier",
                "position_groups",
                "plot_series",
                "records"
              ],
              "properties": {
                "kmer_size": {
                  "type": "integer",
                  "minimum": 1
                },
                "sampled_every_n_reads": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Current fastqc-rs implementation inspects every Nth read for Kmer enrichment."
